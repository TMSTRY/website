# YouTube Channel ID — find it in YouTube Studio > Settings > Channel > Advanced Settings
# Starts with UC, e.g. UCxxxxxxxxxxxxxxxxxxxxxxxx
YOUTUBE_CHANNEL_ID=UCxxxxxxxxxxxxxxxxxxxxxxxx

# Sanity
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production

# Sanity API token — REQUIRED for likes & comments (server-side writes).
# Must have Editor (write) permission. Create at https://sanity.io/manage
SANITY_API_TOKEN=your_write_token

# Secret shared with the Sanity webhook that calls /api/revalidate
REVALIDATE_SECRET=your_secret
